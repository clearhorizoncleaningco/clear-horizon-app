# =============================================================================
# Clear Horizon Cleaning Co. — environment variables
# Copy to `.env` and fill in. NEVER commit `.env` (only this example is tracked).
# =============================================================================

# --- Supabase (Project Settings > API) --------------------------------------
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only secret (Project Settings > API > service_role). NEVER expose client-side.
# Used only by the seed script to create the Admin auth user.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# --- Database (Project Settings > Database > Connection string) --------------
# DATABASE_URL = pooled connection (Transaction mode, port 6543, pgbouncer=true)
#   used by the app at runtime.
# DIRECT_URL   = direct connection (Session mode, port 5432) used for migrations.
# Replace [PASSWORD] and the project ref/region with your values.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-ref:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- App ---------------------------------------------------------------------
# Public base URL of the app. Used for magic-link / OAuth email redirects.
# Local: http://localhost:3000 · Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Seed values (used once by `npm run db:seed`) ----------------------------
SEED_ORG_NAME="Clear Horizon Cleaning Co."
SEED_ORG_SLUG="clear-horizon"
SEED_ADMIN_EMAIL="admin@clearhorizoncleaners.com"
SEED_ADMIN_PASSWORD="choose-a-strong-password"
SEED_ADMIN_NAME="Clear Horizon Admin"

# --- Phase 3 sample data + photo storage (optional) --------------------------
# `npm run db:seed:sample` creates a demo Cleaner + sample estimates/jobs/photos
# so the dashboard, reports, calibration and a customer report show live data.
# The cleaner password defaults to SEED_ADMIN_PASSWORD unless set here.
SEED_CLEANER_EMAIL="cleaner@clearhorizoncleaners.com"
SEED_CLEANER_PASSWORD=""
SEED_CLEANER_NAME="Sam Cleaner"
# Before/after photo uploads use a PUBLIC Supabase Storage bucket "job-photos".
# Create it once with `npm run setup:storage` (uses SUPABASE_SERVICE_ROLE_KEY).

# --- Feature flags (Phase 2+ — stubbed OFF in Phase 0/1) ---------------------
# One-way push of finished quotes to GoHighLevel. Leave disabled until creds added.
GHL_PUSH_ENABLED="false"
GHL_WEBHOOK_URL=""
